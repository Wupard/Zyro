rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return authed() && (
        me().isAdmin == true ||
        request.auth.token.email == 'wupard@gmail.com' ||
        me().data.userRank == 'mod' ||
        me().data.userRank == 'admin'
      );
    }

    match /users/{userId} {
      allow read: if authed();
      allow create: if authed() && request.auth.uid == userId;
      allow update: if authed() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.isAdmin == resource.data.isAdmin &&
          request.resource.data.data.userRank == resource.data.data.userRank
        )
      );
      allow delete: if false;

      match /notifications/{nid} {
        allow read: if authed() && request.auth.uid == userId;
        allow update: if authed() && request.auth.uid == userId;
        allow create: if authed() && (
          request.auth.uid == userId ||
          isAdmin()
        );
        allow delete: if authed() && request.auth.uid == userId;
      }
    }

    match /notifications/{nid} {
      allow read: if authed();
      allow create, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if authed();
      allow create: if authed()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 5000;
      allow delete: if authed() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow update: if false;
    }

    match /public_comments/{commentId} {
      allow read: if authed();
      allow create: if authed()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 5000;
      allow delete: if authed() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow update: if authed()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['upvotes','upvotedBy']);
    }

    match /systemAnnouncements/{aid} {
      allow read: if authed();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /admin_notifications/{id} {
      allow create: if authed();
      allow read, update, delete: if isAdmin();
    }

    match /app_state/{id} {
      allow read: if authed();
      allow create, update, delete: if isAdmin();
    }

    match /bans/{banId} {
      allow get: if authed() && (request.auth.uid == banId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
